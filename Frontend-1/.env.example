# Copy to `.env.local` in this folder (`Frontend-1`). CRA reads it on `npm start`.
#
# Backend env (repo root `.env`): set AUTH_OPTIONAL=0 and full AUTH0_* when testing
# this UI with real login. For chat-only local tests, skip this app and use
# anonymous user + http://127.0.0.1:8000 instead.

REACT_APP_AUTH0_DOMAIN=dev-xxxx.us.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your_spa_client_id
REACT_APP_AUTH0_AUDIENCE=https://your-api-identifier

REACT_APP_API_BASE_URL=http://127.0.0.1:8000
REACT_APP_CHATBOT_URL=http://127.0.0.1:8000
