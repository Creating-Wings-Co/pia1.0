# Copy to `.env.local` in this folder (`Frontend-1`). CRA reads it on `npm start`.
# On Vercel: Project Settings → Environment Variables (then redeploy).

# --- Auth0 (SPA application) ---
REACT_APP_AUTH0_DOMAIN=dev-1kv1ttbnzexy1kly.us.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your_spa_client_id
# Must match EC2 AUTH0_AUDIENCE exactly
REACT_APP_AUTH0_AUDIENCE=https://chat.creatingwings.org/api
# Must match Auth0 Allowed Callback URLs
REACT_APP_AUTH0_REDIRECT_URI=https://pia1-0.vercel.app/post-login

# --- Backend (EC2) ---
REACT_APP_API_BASE_URL=https://chat.creatingwings.org
REACT_APP_CHATBOT_URL=https://chat.creatingwings.org

# --- Local dev overrides ---
# REACT_APP_AUTH0_REDIRECT_URI=http://localhost:3000/post-login
# REACT_APP_API_BASE_URL=http://127.0.0.1:8000
# REACT_APP_CHATBOT_URL=http://127.0.0.1:8000
