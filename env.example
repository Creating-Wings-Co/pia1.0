# Copy to `.env` in this directory (repo root). Never commit real secrets.
# Validate: `python -c "from config import Config; Config.validate(for_chat_api=True)"`

# --- Core API (always required for chat) ---
GOOGLE_GEMINI_API_KEY=
MONGODB_URI=
# Database name in MongoDB (collections: users, chats)
MONGODB_DB=creating_wings

# --- Local dev without Auth0 ---
# ENVIRONMENT=development (default) allows skipping Auth0 in startup checks.
# AUTH_OPTIONAL=1 (default in non-production): do not require AUTH0_DOMAIN at startup.
# Chat: POST /api/user/anonymous then POST /api/chat with user_id.
# Set AUTH_OPTIONAL=0 when testing the React app + JWT (then set AUTH0_DOMAIN, etc.).
ENVIRONMENT=development
AUTH_OPTIONAL=1

# --- Auth0 (required in production; required in dev when AUTH_OPTIONAL=0) ---
AUTH0_DOMAIN=
# API identifier; must match SPA REACT_APP_AUTH0_AUDIENCE when verifying tokens
AUTH0_AUDIENCE=
# Used by Auth0 dashboard / M2M only — not used for JWT verification in this API
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_NEXTJS_URL=http://localhost:3000

# --- RAG / vectors ---
VECTOR_DB_PATH=./vector_db
KNOWLEDGE_BASE_PATH=./DATABSE
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Logging ---
# Production defaults DISABLE_CONSOLE_LOGS on when ENVIRONMENT=production
DISABLE_CONSOLE_LOGS=false
LOG_LEVEL=INFO

# --- Misc ---
CONVERSATION_MAX_MESSAGES=15
# If your shell has stale exports, use DOTENV_OVERRIDE=1 when starting uvicorn
# DOTENV_OVERRIDE=1
